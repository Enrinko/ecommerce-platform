{
  "expo": {
    "name": "Measured",
    "slug": "measured-mobile",
    "scheme": "measured",
    "version": "0.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "android": {
      "package": "com.measured.mobile",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-status-bar",
      "./plugins/with-cleartext-dev-hosts"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
